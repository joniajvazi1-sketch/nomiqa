# Cache static assets with content hashes for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache region images
/regions/*
  Cache-Control: public, max-age=31536000, immutable

# Cache logo and public images
/nomiqa-logo.jpg
  Cache-Control: public, max-age=31536000, immutable

/nomiqa-og-image.jpg
  Cache-Control: public, max-age=31536000, immutable

/nomiqa-token-logo.png
  Cache-Control: public, max-age=31536000, immutable

# Default: do NOT aggressively cache HTML or route responses.
# (Only /assets/* and explicit public images should be immutable.)
/*
  Cache-Control: public, max-age=0, must-revalidate

# HTML pages - shorter cache with revalidation
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate
