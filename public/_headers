# Cache static assets with content hashes for 1 year (must be before generic rules)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache region images
/regions/*
  Cache-Control: public, max-age=31536000, immutable

# Cache all public images by extension
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.gif
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

# Cache JavaScript and CSS files (hashed)
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Default: HTML and routes - no aggressive caching
/*
  Cache-Control: public, max-age=0, must-revalidate
