# Cache static assets with content hashes for 1 year (must be before generic rules)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache region images
/regions/*
  Cache-Control: public, max-age=31536000, immutable

# Cache all public images by extension
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.gif
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

# Cache JavaScript and CSS files (hashed)
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# HTML files - never cache to ensure fresh JS/CSS references
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Default: HTML and routes - no aggressive caching
/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
